{
  "functions": {
    "app/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/backup",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/agent-scan",
      "schedule": "7 * * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/email-scan",
      "schedule": "*/15 * * * *"
    }
  ]
}
